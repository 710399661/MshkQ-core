{
    "name": "mshkq/core",
    "description": "The MshkQ Framework",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "dragonmantank/cron-expression": "^3.0",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/bus": "^10.0",
        "illuminate/cache": "^10.0",
        "illuminate/config": "^10.0",
        "illuminate/container": "^10.0",
        "illuminate/database": "^10.0",
        "illuminate/encryption": "^10.0",
        "illuminate/events": "^10.0",
        "illuminate/filesystem": "^10.0",
        "illuminate/hashing": "^10.0",
        "illuminate/http": "^10.0",
        "illuminate/notifications": "^10.0",
        "illuminate/queue": "^10.0",
        "illuminate/redis": "^10.0",
        "illuminate/session": "^10.0",
        "illuminate/validation": "^10.0",
        "illuminate/view": "^10.0",
        "intervention/image": "^3.0",
        "laminas/laminas-diactoros": "^2.25",
        "laminas/laminas-httphandlerrunner": "^1.5",
        "laminas/laminas-stratigility": "^3.8",
        "lcobucci/jwt": "^4.3",
        "league/flysystem": "^3.0",
        "league/oauth2-server": "^8.3",
        "monolog/monolog": "^3.0",
        "nikic/fast-route": "^1.3.0",
        "opis/closure": "^4.5",
        "overtrue/easy-sms": "^3.0",
        "phpoffice/phpspreadsheet": "^1.29",
        "qcloud/cos-sdk-v5": "^2.6",
        "ramsey/uuid": "^4.7",
        "symfony/console": "^6.0",
        "tencentcloud/tencentcloud-sdk-php": "^3.0",
        "mshkq/json-api": "dev-main"
    },
    "autoload": {
        "files": [
            "src/Foundation/helpers.php"
        ],
        "psr-4": {
            "MshkQ\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "*": true
        },
        "platform": {
            "php": "8.1.0"
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    }
}
